{
  "compilerOptions": {
    "target": "ES2021",
    "rootDir": "./src",
    "outDir": "./dist/",
    "module": "node16",
    "declaration": true,
    "noImplicitAny": true,
    "removeComments": true,
    "moduleResolution": "node16",
    "allowJs": true,
    "sourceMap": false,
    "strictNullChecks": true,
    "alwaysStrict": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "types": ["jest"],
    "lib": ["ES2021"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "examples"]
}
